include LICENCE RELEASE-NOTES AUTHORS
include README.md
include electrum-blk.desktop
include *.py
include run_electrum
include org.blackcoin.electrum-blk.metainfo.xml
recursive-include packages *.py
recursive-include packages cacert.pem

include contrib/requirements/requirements*.txt
include contrib/deterministic-build/requirements*.txt
include contrib/*.sh

graft electrum_blk
graft tests
graft contrib/udev

exclude electrum_blk/*.so
exclude electrum_blk/*.so.0
exclude electrum_blk/*.dll
exclude electrum_blk/*.dylib

global-exclude __pycache__
global-exclude *.py[co~]
global-exclude *.py.orig
global-exclude *.py.rej
global-exclude .git

# We include both source (.po) and compiled (.mo) locale files (if present).
# When building the "sourceonly" tar.gz, the build script explicitly deletes the compiled files.
# exclude electrum_blk/locale/locale/*/LC_MESSAGES/electrum.mo
